{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",

        /* Bundler mode */
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "moduleDetection": "force",

        /* Linting */
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true
    },
    "include": [
        "src/**/*"
    ],
}
